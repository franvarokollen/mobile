{
  "version": 2,
  "routes": [
    { "src": "/api/students/bulk", "dest": "/api/students-bulk" },
    { "src": "/api/(.*)",          "dest": "/api/$1" },
    { "src": "/css/(.*)",          "dest": "/css/$1" },
    { "src": "/js/(.*)",           "dest": "/js/$1" },
    { "src": "/(.*)",              "dest": "/index.html" }
  ]
}
