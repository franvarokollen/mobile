# Copy this file to .env (for local vercel dev) — never commit .env
# Get these values from: https://app.supabase.com → your project → Settings → API

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Identifies your school in the database.
# Use a short slug: "springfield-high", "demo", etc.
# When SSO is added this becomes per-user automatically.
SCHOOL_ID=my-school
